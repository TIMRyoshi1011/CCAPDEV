<div class="dashboard" style="margin-top: 40px; margin-left: 280px;">
    <!-- Left Panel -->
    <div>
        <!-- Profile -->
        <div class="profile-card" style="padding: 0;">
            <div class="profile-header"></div>
            <div class="profile-avatar">{{currentUser.avatar}}</div>

            <div class="profile-content">
                <h2>
                    {{currentUser.name}}
                    <span class="badge platinum">{{currentUser.currentTierIcon}} {{currentUser.currentTier}}
                    </span>

                    {{#if currentUser.verified}}
                    <span class="badge verified">Verified</span>
                    {{/if}}
                </h2>

                <p>@{{currentUser.username}}</p>
                <br>

                <p>{{currentUser.bio}}</p>
                <p>📅 Joined {{currentUser.memberSince}}</p>

                <br>
                <hr>

                <button class="edit-btn" onclick="openEditProfilePopup()">Edit Profile</button>

                <div class="stats-row">
                    <div><strong>{{currentUser.totalReviews}}</strong><br>Reviews</div>
                    <div><strong>{{currentUser.comments}}</strong><br>Comments</div>
                    <div><strong>{{currentUser.points}}</strong><br>Points</div>
                </div>

                <!-- Tier Progress Bar -->
                <div class="tier-progress">
                    <div class="tier-info">
                        <span class="tier-badge">{{currentUser.currentTierIcon}} {{currentUser.currentTier}}</span>
                        {{#if currentUser.nextTier}}
                        <span class="tier-next">{{currentUser.pointsToNext}} points to {{currentUser.nextTierIcon}} {{currentUser.nextTier}}</span>
                        {{else}}
                        <span class="tier-max">Max Tier Reached!</span>
                        {{/if}}
                    </div>
                    <div class="progress-bar">
                        <div class="progress-fill" style="width: {{currentUser.progress}}%"></div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Edit Profile Popup -->
        <div id="editProfilePopup" class="popup hidden">
            <div class="popup-content">
                <span class="close" onclick="closeEditProfilePopup()">&times;</span>
                <h2>Edit Profile</h2>
                <br>
                <form onsubmit="submitProfileUpdate(event)">
                    <div class="form-group">
                        <label>Change Display Name</label>
                        <input type="text" name="name" value="{{currentUser.name}}">
                    </div>
                    <br>
                    <div class="form-group">
                        <label>Change Username</label>
                        <input type="text" name="username" value="{{currentUser.username}}">
                    </div>
                    <br>
                    <div class="form-group">
                        <label>Change Email</label>
                        <input type="email" name="email" value="{{currentUser.email}}">
                    </div>
                    <br>
                    <div class="form-group">
                        <label>Edit Bio</label>
                        <input type="text" name="bio" value="{{currentUser.bio}}">
                    </div>
                    <br>
                    <button type="submit" class="submit-btn">Update Profile</button>

                </form>
            </div>
        </div>

        <!-- Stats -->
        <div class="profile-card">
            <h3>📊 Stats</h3>

            <p>Avg Rating ⭐ {{currentUser.avgRating}}</p>
            <p>Total Upvotes 👍 {{currentUser.upvotes}}</p>
            <p>Total Downvotes 👎 {{currentUser.downvotes}}</p>

            <br>
            <hr>
            <br>

            <h4>Top Cuisines</h4>

            <ul style="padding:10px;">
                {{#each currentUser.topCuisines}}
                <li>{{name}} ({{count}})</li>
                {{/each}}
            </ul>

            <br>
            <hr>
            <br>

            <h4>Top Locations</h4>

            <ul style="padding:10px;">
                {{#each currentUser.topLocations}}
                <li>{{name}} ({{count}})</li>
                {{/each}}
            </ul>
        </div>

        <!-- Achievements -->
        <div class="profile-card">
            <h3>🏅 Achievements</h3>

            {{#each currentUser.achievements}}
            <p>{{this}}</p>
            {{/each}}

        </div>
    </div>

    <!-- Right Panel -->
    <div>

        <div class="tabs">
            <span class="active">Reviews</span>
            <span onclick="goToActivity()">Activity</span>
        </div>
        {{#each reviews}}

        <div class="review-card-3">

            <div class="review-header-3">
                <h3>{{restaurant}}</h3>

                {{#if ownPost}}
                <div class="options-container-3" data-post-id="{{_id}}">
                    <div class="options">...</div>

                    <div class="options-dropdown-3">
                        <div class="option-item-3" onclick="editReview('{{_id}}')">✏️ Edit</div>
                        <div class="option-item-3" onclick="deleteReview('{{_id}}')">🗑️ Delete</div>
                    </div>
                </div>
                {{/if}}
            </div>
            <div class="review-user-3">

                <div class="small-avatar">{{../currentUser.avatar}}</div>

                <div>
                    <strong>{{../currentUser.name}}</strong>

                    <span class="badge platinum">
                        {{../currentUser.currentTierIcon}} {{../currentUser.currentTier}}
                    </span>

                    {{#if ../currentUser.verified}}
                    <span class="badge verified">✔ Verified</span>
                    {{/if}}

                    <div style="font-size:12px; color:#777;">
                        {{formatDate date}}
                    </div>
                </div>

                <div class="rating-3 star-rating">
                    {{{renderStars ratingValue}}}
                    <span class="rating-number">{{ratingValue}}</span>
                </div>
            </div>

            <br>

            {{#if cuisine}}
            <span class="badge-cuisine">🍽️ {{cuisine}}</span>
            {{/if}}
            
            {{#if location}}
            <span class="badge location">📍 {{location}}</span>
            {{/if}}

            <br>
            <br>
            
            <div class="review-scores">
                <div class="score-item">
                    <span class="score-label">Service:</span>
                    <div class="star-rating small">
                        {{{renderStars scores.service}}}
                    </div>
                </div>
                <div class="score-item">
                    <span class="score-label">Taste:</span>
                    <div class="star-rating small">
                        {{{renderStars scores.taste}}}
                    </div>
                </div>
                <div class="score-item">
                    <span class="score-label">Ambiance:</span>
                    <div class="star-rating small">
                        {{{renderStars scores.ambiance}}}
                    </div>
                </div>
            </div>

            <div class="review-title-3">
                {{title}}
            </div>

            <div class="review-text-3">
                {{content}}
            </div>
            <br>
            <hr>
            <br>
            <div class="review-actions">
                <button class="vote-btn upvote-btn {{userVoteClass this}}" data-post-id="{{toString _id}}" data-action="upvote">👍 {{likes}}</button>
                <button class="vote-btn downvote-btn {{userVoteClass this 'downvote'}}" data-post-id="{{toString _id}}" data-action="downvote">👎 {{dislikes}}</button>
                <span class="toggle-comments">💬 {{comments.length}} Comments ▶</span>
            </div>

            <div class="comments-section">
                {{#each comments}}
                <div class="comment-item">
                    <div class="comment-avatar {{currentUser.rankClass}}">{{currentUser.initials}}</div>
                    <div class="review-user-info">
                        <highlight>{{currentUser.name}} <span class="review-date">· {{formatDate date}}</span></highlight>
                        <div class="review-text-2">{{text}}</div>
                    </div>
                </div>
                {{/each}}

                <!-- Add Comment Form -->
                <div class="add-comment">
                    {{#if ../currentUser.name}}
                    <div class="comment-avatar {{../currentUser.rankClass}}">{{../currentUser.avatar}}</div>
                    {{else}}
                    <div class="comment-avatar">?</div>
                    {{/if}}
                    <div class="comment-input-container">
                        <input type="text" class="comment-input" placeholder="Write a comment..." data-post-id="{{toString _id}}">
                        <button class="comment-submit-btn" data-post-id="{{toString _id}}">Post</button>
                    </div>
                </div>
            </div>
        </div>
        {{/each}}

    </div>

</div>