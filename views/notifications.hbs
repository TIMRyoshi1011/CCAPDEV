<div class="main-content-2">
    <!-- Notifications Header -->
    <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 30px;">
        <h1 style="color: #1a1a1a; font-size: 28px; margin: 0;">Notifications</h1>
    </div>

    <!-- Notifications List -->
    <div class="notifications-list">

        {{#each notifications}}
        <div class="activity-card">
            <div class="activity-header">
                <div class="icon-3">{{icon}}</div>
                <div>
                    <div class="title">{{title}}</div>
                    <div class="date">{{formatDate date}}</div>
                </div>
                {{#if rating}}
                <div class="rating">
                    {{{renderStars rating}}}
                    <span class="rating-score">{{rating}}</span>
                </div>
                {{/if}}
            </div>

            {{#if reviewTitle}}
            <div class="review-title-3">{{reviewTitle}}</div>
            {{/if}}

            <p class="activity-text">{{content}}</p><br>

            {{#if footer}}
            <div class="activity-footer">
                {{#if footer.likes}}<span>👍 {{footer.likes}}</span>{{/if}}
                {{#if footer.dislikes}}<span>👎 {{footer.dislikes}}</span>{{/if}}
                {{#if footer.comments}}<span>💬 {{footer.comments}}</span>{{/if}}
                {{#if footer.author}}<span>By {{footer.author}}</span>{{/if}}
            </div>
            {{/if}}
        </div>
        {{/each}}
        
        {{#unless notifications.length}}
        <div style="text-align: center; padding: 40px; color: #666;">
            <p>No notifications yet.</p>
        </div>
        {{/unless}}

    </div>
</div>
