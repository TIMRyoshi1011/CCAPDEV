<div class="main-content-2">
    <!-- STATS CARDS -->
    <div class="stats-grid">
        <div class="stat-card">
            <h4>📝Total Reviews</h4>
            <h2>{{currentUser.totalReviews}}</h2>
        </div>
        <div class="stat-card">
            <h4>🍽️ TOP CUISINE</h4>
            <h2>{{currentUser.topCuisine}}</h2>
        </div>
        <div class="stat-card">
            <h4>⭐ AVG RATING</h4>
            <h2>{{currentUser.avgRating}}★</h2>
        </div>
        <div class="stat-card">
            <h4>📍 LOCATIONS</h4>
            <h2>{{currentUser.locations}}</h2>
        </div>
        <div class="stat-card">
            <h4>🔥 Top Rated</h4>
            <h2>{{currentUser.topRated}}</h2>
        </div>
    </div>

    <!-- Filters -->
    <div class="filters">
        <form id="filterForm" action="/feed" method="GET" style="display: flex; gap: 15px; align-items: center;">
            <div class="filter-group">
                <span>🍽️</span>
                <select name="cuisine" onchange="this.form.submit()">
                    <option value="">Cuisine: All</option>
                    {{#each cuisines}}
                    <option value="{{this}}" {{#if (eq ../selectedCuisine this)}}selected{{/if}}>{{this}}</option>
                    {{/each}}
                </select>
            </div>

            <div class="filter-group">
                <span>📍</span>
                <select name="location" onchange="this.form.submit()">
                    <option value="">Location: All</option>
                    {{#each locations}}
                    <option value="{{this}}" {{#if (eq ../selectedLocation this)}}selected{{/if}}>{{this}}</option>
                    {{/each}}
                </select>
            </div>

            <div class="filter-group">
                <span>🕒</span>
                <select name="sort" onchange="this.form.submit()">
                    {{#each sortOptions}}
                    <option value="{{this}}" {{#if (eq ../selectedSort this)}}selected{{/if}}>{{this}}</option>
                    {{/each}}
                </select>
            </div>
        </form>

        <button class="write-review-btn" onclick="window.location.href='/write-review'">
            ✏️ Write a Review
        </button>

        <div class="view-toggle">
            <button class="active">◼️ Grid</button>
            <button>☰ List</button>
        </div>
    </div>

    <!-- Reviews -->
    <div class="review-grid-2">
        {{#each posts}}
        <div class="review-card-2" data-user-vote="{{userVote}}">
            <div class="review-header">
                <h3>{{restaurant}}</h3>
                <div class="options-container" data-post-id="{{_id}}">
                    {{#if ownPost}}
                    <div class="options">...</div>
                    <div class="options-dropdown">
                        <div class="option-item" onclick="editReview('{{_id}}')">✏️ Edit</div>
                        <div class="option-item" onclick="deleteReview('{{_id}}')">🗑️ Delete</div>
                    </div>
                    {{else}}
                    <div class="options">...</div>
                    <div class="options-dropdown">
                        <div class="option-item" onclick="reportReview('{{_id}}', this)">🚩 Report</div>
                    </div>
                    {{/if}}
                </div>
            </div>

            <div class="review-user-2">
                <div class="review-avatar {{currentUser.rankClass}}">{{currentUser.avatar}}</div>
                <div class="review-user-info">
                    <div>
                        <highlight>{{currentUser.name}}</highlight>
                        <span class="badge {{currentUser.rankClass}}">{{currentUser.badge}}</span>
                        {{#if currentUser.verified}}
                        <span class="verified-2">✔ Verified</span>
                        {{/if}}
                    </div>
                    <div class="review-date">{{date}}</div>
                </div>
            </div>

            <div class="review-meta-row" style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 15px; margin-top: 10px;">
                <div class="review-meta-left" style="display: flex; gap: 10px;">
                    {{#if cuisine}}
                    <span class="badge-cuisine">{{cuisine}}</span>
                    {{/if}}
                    {{#if location}}
                    <span class="badge-location">📍 {{location}}</span>
                    {{/if}}
                </div>
                <div class="star-rating">
                    {{{renderStars ratingValue}}}
                    <span class="rating-number">{{ratingValue}}</span>
                </div>
            </div>

            <div class="review-scores">
                <div class="score-item">
                    <span class="score-label">Service:</span>
                    <div class="star-rating small">
                        {{{renderStars scores.service}}}
                    </div>
                </div>
                <div class="score-item">
                    <span class="score-label">Taste:</span>
                    <div class="star-rating small">
                        {{{renderStars scores.taste}}}
                    </div>
                </div>
                <div class="score-item">
                    <span class="score-label">Ambiance:</span>
                    <div class="star-rating small">
                        {{{renderStars scores.ambiance}}}
                    </div>
                </div>
            </div>

            <div class="review-title-2">{{title}}</div>
            <div class="review-text-2">{{content}}</div>

            <div class="review-actions">
                <button class="vote-btn upvote-btn {{userVoteClass this}}" data-post-id="{{toString _id}}" data-action="upvote">👍 {{likes}}</button>
                <button class="vote-btn downvote-btn {{userVoteClass this 'downvote'}}" data-post-id="{{toString _id}}" data-action="downvote">👎 {{dislikes}}</button>
                <span class="toggle-comments">💬 {{comments.length}} Comments ▶</span>
            </div>

            <div class="comments-section">
                {{#each comments}}
                <div class="comment-item">
                    <div class="comment-avatar {{currentUser.rankClass}}">{{currentUser.initials}}</div>
                    <div class="review-user-info">
                        <highlight>{{currentUser.name}} <span class="review-date">· {{date}}</span></highlight>
                        <div class="review-text-2">{{text}}</div>
                    </div>
                </div>
                {{/each}}
                
                <!-- Add Comment Form -->
                <div class="add-comment">
                    <div class="comment-avatar {{../currentUser.rankClass}}">{{../currentUser.avatar}}</div>
                    <div class="comment-input-container">
                        <input type="text" class="comment-input" placeholder="Write a comment..." data-post-id="{{toString _id}}">
                        <button class="comment-submit-btn" data-post-id="{{toString _id}}">Post</button>
                    </div>
                </div>
            </div>
        </div>
        {{/each}}
    </div>
</div>