<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{pageTitle}} - BiteBack</title>
    <link rel="stylesheet" href="/style.css">
    <!-- <link rel="stylesheet" href="feed.css"> -->
</head>

<body>
    <!--MAIN SIDEBAR (COPY THIS STYLE FOR THE REST OF THE PAGES)-->
    <div class="sidebar">
        <div class="sidebar-logo" onclick="goToFeed()" style="cursor: pointer;">
            Bite<span>Back</span>
        </div>

        <div class="sidebar-user">
            <div class="sidebar-avatar">{{currentUser.avatar}}</div>
            <div class="sidebar-user-info">
                <h4>{{currentUser.name}}</h4>
                <!-- <div class="sidebar-username">@{{currentUser.displayUsername}}</div> -->
                <div class="user-badge {{currentUser.rankClass}}">{{currentUser.badge}} • {{#if currentUser.points}}{{currentUser.points}}{{else}}0{{/if}} pts</div>
            </div>
        </div>

        <div class="sidebar-nav">
            <div class="sidebar-nav-item {{#if (eq activePage 'feed')}}active{{/if}}" onclick="goToFeed()">
                🏠 Feed
            </div>
            <div class="sidebar-nav-item {{#if (eq activePage 'notifs')}}active{{/if}}" onclick="goToNotifications()">
                🔔 Notifications
                {{#if notifications.length}}
                <span class="notif-badge">{{notifications.length}}</span> 
                {{/if}}
            </div>
            <div class="sidebar-nav-item {{#if (eq activePage 'profile')}}active{{/if}}" onclick="goToProfile()">
                👤 Profile
            </div>
            <div class="sidebar-nav-item {{#if (eq activePage 'settings')}}active{{/if}}" onclick="goToSettings()">
                ⚙️ Settings
            </div>
        </div>

        <div class="sidebar-logout" onclick="logout()">
            🚪 Log Out
        </div>
    </div>
    <!--============= END OF SIDEBAR ============= -->

    {{{body}}}

    <!-- Global Alert Popup -->
    <div id="customAlertPopup" class="popup hidden">
        <div class="popup-content" style="text-align: center;">
            <span class="close" onclick="closeCustomAlert()">&times;</span>
            <div class="success-icon-container">
                <span>✓</span>
            </div>
            <h2 class="success-title">Notice</h2>
            <p id="customAlertMessage" class="success-message"></p>
            <button class="success-done-btn" onclick="closeCustomAlert()">OK</button>
        </div>
    </div>

    <!-- Global Confirm Popup -->
    <div id="customConfirmPopup" class="popup hidden">
        <div class="popup-content" style="text-align: center;">
            <span class="close" onclick="closeCustomConfirm(false)">&times;</span>
            <div class="success-icon-container" style="background-color: #f59e0b; box-shadow: 0 4px 12px rgba(245, 158, 11, 0.3);">
                <span>?</span>
            </div>
            <h2 class="success-title">Confirm</h2>
            <p id="customConfirmMessage" class="success-message"></p>
            <div style="display: flex; justify-content: center; gap: 12px; margin-top: 20px;">
                <button class="success-done-btn" onclick="closeCustomConfirm(true)" style="width: 120px; background-color: #d94866;">Yes</button>
                <button class="success-done-btn" onclick="closeCustomConfirm(false)" style="width: 120px; background-color: #f3f4f6; color: #4b5563; box-shadow: none;">Cancel</button>
            </div>
        </div>
    </div>

    <!-- Global Delete Comment Confirm Popup -->
    <div id="deleteCommentPopup" class="popup hidden">
        <div class="popup-content" style="text-align: center;">
            <span class="close" onclick="closeDeleteCommentPopup()">&times;</span>
            <div class="success-icon-container" style="background-color: #f59e0b; box-shadow: 0 4px 12px rgba(245, 158, 11, 0.3);">
                <span>?</span>
            </div>
            <h2 class="success-title">Confirm</h2>
            <p class="success-message">Delete this comment?</p>
            <div style="display: flex; justify-content: center; gap: 12px; margin-top: 20px;">
                <button class="success-done-btn" onclick="confirmDeleteComment()" style="width: 120px; background-color: #d94866;">Delete</button>
                <button class="success-done-btn" onclick="closeDeleteCommentPopup()" style="width: 120px; background-color: #f3f4f6; color: #4b5563; box-shadow: none;">Cancel</button>
            </div>
        </div>
    </div>

    <!-- Report Post Popup -->
    <div id="reportReviewPopup" class="popup hidden">
        <div class="popup-content">
            <span class="close" onclick="closeReportPopup()">&times;</span>
            <div class="report-header">
                <h2 class="report-title">
                    <span class="report-title-icon">🚩</span> Report this post?
                </h2>
                <p class="report-description">This will flag the post for review. Please tell us why.</p>
            </div>
            
            <div class="report-textarea-group">
                <textarea id="report-reason" class="report-textarea" rows="3" placeholder="Reason for reporting..." required></textarea>
            </div>

            <div id="report-error-msg" class="form-error-message"></div>

            <div class="report-actions">
                <button class="submit-btn report-cancel-btn" onclick="closeReportPopup()">Cancel</button>
                <button class="submit-btn report-confirm-btn" onclick="submitReport()">Report</button>
            </div>
        </div>
    </div>

    <!-- User Profile Modal -->
    <div id="userProfileModal" class="modal-backdrop hidden" onclick="closeModalOnBackdrop(event)">
        <div class="modal-container" onclick="event.stopPropagation()">
            <!-- Header -->
            <div class="modal-header" id="modalHeader">
                <button class="modal-close-btn" onclick="closeModal()">✕</button>

                <div class="user-info-row">
                    <div class="user-avatar" id="userAvatar"></div>
                    <div class="user-details">
                        <h2 class="user-name" id="userName"></h2>
                        <div class="user-username" id="userUsername"></div>
                        <div class="user-badges">
                            <span class="tier-pill" id="userTier"></span>
                            <span class="verified-badge hidden" id="verifiedBadge">✓</span>
                        </div>
                    </div>
                </div>

                <div class="user-bio" id="userBio"></div>
                <div class="user-joined" id="userJoined"></div>
            </div>

            <!-- Body -->
            <div class="modal-body">
                <!-- Stats Grid -->
                <div class="modal-stats-grid">
                    <div class="modal-stat-card">
                        <div class="stat-icon">📝</div>
                        <div class="stat-value" id="statReviews" style="color: var(--cerise);"></div>
                        <div class="stat-label">Reviews</div>
                    </div>
                    <div class="modal-stat-card">
                        <div class="stat-icon">🏅</div>
                        <div class="stat-value" id="statPoints" style="color: var(--citron);"></div>
                        <div class="stat-label">Points</div>
                    </div>
                    <div class="modal-stat-card">
                        <div class="stat-icon" id="statTierIcon"></div>
                        <div class="stat-value" id="statTier"></div>
                        <div class="stat-label">Tier</div>
                    </div>
                </div>

                <!-- Preferences -->
                <h3 class="section-heading">Preferences</h3>
                <div class="preferences-grid">
                    <div class="preference-card">
                        <div class="preference-label">🍜 Favorite Cuisine</div>
                        <div class="preference-value" id="prefCuisine"></div>
                    </div>
                    <div class="preference-card">
                        <div class="preference-label">📍 Top Location</div>
                        <div class="preference-value" id="prefLocation"></div>
                    </div>
                </div>

                <!-- Average Ratings -->
                <div id="ratingsSection">
                    <h3 class="section-heading">⭐ Average Ratings</h3>
                    <div class="ratings-container">
                        <div class="rating-row">
                            <span class="rating-label">Service</span>
                            <div class="rating-value-container">
                                <div class="modal-stars" id="serviceStars"></div>
                                <span class="rating-number" id="serviceRating"></span>
                            </div>
                        </div>
                        <div class="rating-row">
                            <span class="rating-label">Taste</span>
                            <div class="rating-value-container">
                                <div class="modal-stars" id="tasteStars"></div>
                                <span class="rating-number" id="tasteRating"></span>
                            </div>
                        </div>
                        <div class="rating-row">
                            <span class="rating-label">Ambiance</span>
                            <div class="rating-value-container">
                                <div class="modal-stars" id="ambianceStars"></div>
                                <span class="rating-number" id="ambianceRating"></span>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- View Full Profile Button -->
            </div>
        </div>
    </div>

    <!-- Report Success Popup -->
    <div id="reportSuccessPopup" class="popup hidden">
        <div class="popup-content" style="text-align: center;">
            <span class="close" onclick="closeReportSuccessPopup()">&times;</span>
            <div class="success-icon-container" style="background-color: #d97706; box-shadow: 0 4px 12px rgba(217, 119, 6, 0.3);">
                <span style="font-size: 28px;">🚩</span>
            </div>
            <h2 class="success-title">Report Submitted</h2>
            <p class="success-message" style="margin-bottom: 24px;">Thank you for helping keep our community safe. We'll review this post and take appropriate action.</p>
            <button class="success-done-btn" onclick="closeReportSuccessPopup()">Done</button>
        </div>
    </div>

    <!-- Update Password Popup -->
    <div id="updatePasswordPopup" class="popup hidden">
        <div class="popup-content">
            <span class="close" onclick="closeUpdatePassword()">&times;</span>
            <div class="report-header">
                <h2 class="report-title">
                    <span class="report-title-icon" style="color: #4b5563;">🔒</span> Change Password
                </h2>
            </div>
            
            <form id="updatePasswordForm" onsubmit="submitUpdatePassword(event); return false;">
                <div class="form-group">
                    <label for="current-password">Current Password</label>
                    <input type="password" id="current-password" required>
                </div>
                
                <div class="form-group">
                    <label for="new-update-password">New Password</label>
                    <input type="password" id="new-update-password" required>
                </div>
                
                <div class="form-group">
                    <label for="confirm-update-password">Confirm New Password</label>
                    <input type="password" id="confirm-update-password" required>
                </div>

                <div class="password-requirements">
                    <strong>Password Requirements</strong>
                    <ul>
                        <li>At least 6 characters long</li>
                        <li>Must not be the same as current password</li>
                    </ul>
                </div>

                <div id="update-pw-error-msg" class="form-error-message"></div>

                <div class="report-actions">
                    <button type="button" class="submit-btn report-cancel-btn" onclick="closeUpdatePassword()">Cancel</button>
                    <button type="submit" class="submit-btn report-submit-btn" style="background: #E94E66;">Change Password</button>
                </div>
            </form>
        </div>
    </div>

    <!-- Password Success Popup -->
    <div id="successPasswordPopup" class="popup hidden">
        <div class="popup-content" style="text-align: center; padding: 40px 20px;">
            <div class="success-icon-container">
                <span>&check;</span>
            </div>
            <h2 class="success-title">Password Changed!</h2>
            <p class="success-message">
                Your password has been updated successfully.<br>
                You can now use your new password to log in.
            </p>
            <button class="success-done-btn" onclick="closeSuccessPassword()">Done</button>
        </div>
    </div>

    <script src="/script.js"></script>
</body>

</html>