<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{pageTitle}} - BiteBack</title>
    <link rel="stylesheet" href="/style.css">
    <!-- <link rel="stylesheet" href="feed.css"> -->
</head>

<body>
    <!--MAIN SIDEBAR (COPY THIS STYLE FOR THE REST OF THE PAGES)-->
    <div class="sidebar">
        <div class="sidebar-logo" onclick="goToFeed()" style="cursor: pointer;">
            Bite<span>Back</span>
        </div>

        <div class="sidebar-user">
            <div class="sidebar-avatar">{{currentUser.avatar}}</div>
            <div class="sidebar-user-info">
                <h4>{{currentUser.name}}</h4>
                <div class="user-badge">{{currentUser.badge}}</div>
            </div>
        </div>

        <div class="sidebar-nav">
            <div class="sidebar-nav-item {{#if (eq activePage 'feed')}}active{{/if}}" onclick="goToFeed()">
                🏠 Feed
            </div>
            <div class="sidebar-nav-item {{#if (eq activePage 'notifs')}}active{{/if}}" onclick="goToNotifications()">
                🔔 Notifications
                {{#if notifications}}
                <span class="notif-badge">{{notifications}}</span> 
                {{/if}}
            </div>
            <div class="sidebar-nav-item {{#if (eq activePage 'profile')}}active{{/if}}" onclick="goToProfile()">
                👤 Profile
            </div>
            <div class="sidebar-nav-item {{#if (eq activePage 'settings')}}active{{/if}}" onclick="goToSettings()">
                ⚙️ Settings
            </div>
        </div>

        <div class="sidebar-logout" onclick="logout()">
            🚪 Log Out
        </div>
    </div>
    <!--============= END OF SIDEBAR ============= -->

    {{{body}}}

    <!-- Global Alert Popup -->
    <div id="customAlertPopup" class="popup hidden">
        <div class="popup-content" style="text-align: center;">
            <span class="close" onclick="closeCustomAlert()">&times;</span>
            <h2 style="margin-bottom: 20px;">Notice</h2>
            <h1 id="customAlertMessage" style="margin-bottom: 30px; font-size: 16px; font-weight: normal; color: #4b5563;"></h1>
            <button class="submit-btn" onclick="closeCustomAlert()" style="width: auto; padding: 10px 40px; margin: 0 auto; display: block;">OK</button>
        </div>
    </div>

    <!-- Global Confirm Popup -->
    <div id="customConfirmPopup" class="popup hidden">
        <div class="popup-content" style="text-align: center;">
            <span class="close" onclick="closeCustomConfirm(false)">&times;</span>
            <h2 style="margin-bottom: 20px;">Confirm</h2>
            <h1 id="customConfirmMessage" style="margin-bottom: 30px; font-size: 16px; font-weight: normal; color: #4b5563;"></h1>
            <div style="display: flex; justify-content: center; gap: 15px;">
                <button class="submit-btn" onclick="closeCustomConfirm(true)" style="width: auto; padding: 10px 30px;">Yes</button>
                <button class="submit-btn" onclick="closeCustomConfirm(false)" style="width: auto; padding: 10px 30px; background: #9ca3af; box-shadow: none;">Cancel</button>
            </div>
        </div>
    </div>

    <script src="/script.js"></script>
</body>

</html>