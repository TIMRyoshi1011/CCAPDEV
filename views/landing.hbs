<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Landing Page</title>
    <link rel="stylesheet" href="style.css">
</head>

<body>
    <!-- Header -->
    <div class="header">
        <h3 class="name" onclick="window.location.href='/'" style="cursor: pointer;">Bite<span>Back</span></h3>

        <div class="buttons">
            <button class="login" onclick="openLoginPopup()">Login</button>
            <button class="sign-up" onclick="openSignUpPopup()">Sign Up</button>
        </div>
    </div>

    <!-- Login Popup -->
    <div id="loginPopup" class="popup hidden">
        <div class="popup-content">
            <span class="close" onclick="closeLoginPopup()">&times;</span>
            <h2>Sign in to Bite<span>Back</span></h2>
            <h1>Please Enter your Login Details Below</h1>
            <form id="loginForm">
                <div class="form-group">
                    <label for="login-email">Email</label>
                    <input type="email" id="login-email" required>
                </div>
                <div class="form-group">
                    <label for="login-password">Password</label>
                    <input type="password" id="login-password" required>
                </div>

                <div id="login-error-msg" class="form-error-message"></div>

                <div class="login-options">
                    <label class="remember-me">
                        <input type="checkbox"> Remember me
                    </label>
                    <a href="#" class="forgot-password" onclick="openForgotPasswordPopup(); return false;">Forgot
                        password?</a>
                </div>
                <button type="submit" class="submit-btn">Login</button>
            </form>

            <p class="popup-footer">Don't have an account? <a href="#" onclick="switchToSignUp()">Sign up here</a></p>
        </div>
    </div>

    <!--Forgot Password Popup-->
    <div id="forgotPasswordPopup" class="popup hidden">
        <div class="popup-content">
            <span class="close" onclick="closeForgotPasswordPopup()">&times;</span>
            <h2>Forgot Password?</h2>
            <h1>Please enter your email address to reset your password</h1>

            <form onsubmit="submitForgotPassword(); return false;">
                <div class="form-group">
                    <label for="forgot-email">Email</label>
                    <input type="email" id="forgot-email" placeholder="example.name@domain.com" required>
                </div>

                <div id="forgot-error-msg" class="form-error-message"></div>

                <button type="submit" class="submit-btn">Submit</button>
            </form>

            <p class="popup-footer">
                <a href="#" onclick="closeForgotPasswordPopup(); openLoginPopup(); return false;">Back to Login</a>
            </p>
        </div>
    </div>

    <!-- Change Password Popup -->
    <div id="changePasswordPopup" class="popup hidden">
        <div class="popup-content">
            <span class="close" onclick="closeChangePassword()">&times;</span>
            <h2>Change Password</h2>
            <h1>Please enter your new password below</h1>

            <form onsubmit="submitChangePassword(); return false;">
                <div class="form-group">
                    <label for="email-code">Code sent on your email</label>
                    <input type="password" id="email-code" required>
                </div>

                <div class="form-group">
                    <label for="new-password">New Password</label>
                    <input type="password" id="new-password" required>
                </div>

                <div class="form-group">
                    <label for="confirm-password">Confirm New Password</label>
                    <input type="password" id="confirm-password" required>
                </div>

                <div id="change-pw-error-msg" class="form-error-message"></div>

                <button type="submit" class="submit-btn">Change Password</button>
            </form>
        </div>
    </div>

    <!-- Sign Up Popup -->
    <div id="signupPopup" class="popup hidden">
        <div class="popup-content">
            <span class="close" onclick="closeSignUpPopup()">&times;</span>
            <h2 style="text-align: center;">Register for your <span style="display:block;">Bite<span>Back</span>
                    Account</span>
            </h2>
            <form id="signupForm">
                <div class="form-group">
                    <label for="signup-name">Full Name</label>
                    <input type="text" id="signup-name" required>
                </div>
                <div class="form-group">
                    <label for="signup-email">Email</label>
                    <input type="email" id="signup-email" placeholder="example.name@domain.com" required>
                </div>
                <div class="form-group">
                    <label for="signup-password">Enter password</label>
                    <input type="password" id="signup-password" required>
                </div>
                <div class="form-group">
                    <label for="signup-confirm">Re-enter password</label>
                    <input type="password" id="signup-confirm" required>
                </div>

                <div id="signup-error-msg" class="form-error-message"></div>

                <button type="submit" class="submit-btn">Register Account</button>
            </form>

            <p class="popup-footer">Already have an account? <a href="#" onclick="switchToLogin()">Login</a></p>
        </div>
    </div>

    <!-- Account Created Popup -->
    <div id="accountCreatedPopup" class="popup hidden">
        <div class="popup-content popup-success">
            <span class="close" onclick="closeAccountSuccess()">&times;</span>
            <h2>Hello <span id="accountName"></span>!</h2>
            <h1 class="success-welcome">Welcome to <span>Bite</span>Back</h1>
            <p class="success-subtitle">Your account has been created successfully.</p>
            <button class="submit-btn" onclick="goToFeed()">Go to Feed</button>
        </div>
    </div>

    <!-- Main (Text) -->
    <section class="main">
        <h1>Discover & Review <br>
            <span>Metro Manila's</span> Best Bites
        </h1>

        <p>
            Real reviews from real foodies. Find hidden gems, share your favorites,
            and earn your way to Diamond tier.
        </p>

        <div class="main-buttons">
            <button class="get-started" onclick="openSignUpPopup()">Get Started</button>
        </div>
    </section>

    <!-- Stats -->
    <section class="stats">
        <div class="stat">
            <h2>{{stats.restaurants}}</h2>
            <p>🍽️ Restaurants</p>
        </div>
        <div class="stat">
            <h2>{{stats.reviews}}</h2>
            <p>📝 Reviews</p>
        </div>
        <div class="stat">
            <h2>{{stats.locations}}</h2>
            <p>📍 Locations</p>
        </div>
        <div class="stat">
            <h2>{{stats.avgRating}}★</h2>
            <p>⭐ Average Rating</p>
        </div>
    </section>

    <!-- Tutorial -->
    <section class="tutorial">
        <h2>How it works</h2>
        <p>Three simple steps to earn your place in the community</p>

        <div class="steps">
            <div class="card">
                <h4>01</h4>
                <h3>Find a Restaurant</h3>
                <p>Search and explore restaurants across Metro Manila.</p>
            </div>

            <div class="card">
                <h4>02</h4>
                <h3>Write Your Review</h3>
                <p>Share your honest experience and help other foodies.</p>
            </div>

            <div class="card">
                <h4>03</h4>
                <h3>Earn & Rise</h3>
                <p>Gain points, level up, and unlock exclusive perks.</p>
            </div>
        </div>
    </section>

    <!-- Top Reviews -->
    <section class="top-reviews">
        <div class="top-header">
            <div>
                <h2>🔥 Top Reviews</h2>
                <p>See what the community is loving right now</p>
            </div>
            <button class="view-all" onclick="window.location='/community-reviews'">View All →</button>
        </div>

        <div class="review-grid-2">
            {{#each topReviews}}
            <div class="review-card-2" data-user-vote="{{userVote}}">
                <div class="review-header">
                    <h3>{{restaurant}}</h3>
                </div>

                <div class="review-user-2">
                    <div class="review-avatar {{currentUser.rankClass}}">{{currentUser.avatar}}</div>
                    <div class="review-user-info">
                        <div>
                            <highlight>{{currentUser.name}}</highlight>
                            <span class="badge {{currentUser.rankClass}}">{{currentUser.badge}}</span>
                            {{#if currentUser.verified}}
                            <span class="verified-2">✔ Verified</span>
                            {{/if}}
                        </div>
                        <div class="review-date">{{date}}</div>
                    </div>
                </div>

                <div class="review-meta-row" style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 15px; margin-top: 10px;">
                    <div class="review-meta-left" style="display: flex; gap: 10px;">
                        {{#if cuisine}}
                        <span class="badge-cuisine">{{cuisine}}</span>
                        {{/if}}
                        {{#if location}}
                        <span class="badge-location">📍 {{location}}</span>
                        {{/if}}
                    </div>
                    <div class="star-rating">
                        {{{renderStars ratingValue}}}
                        <span class="rating-number">{{ratingValue}}</span>
                    </div>
                </div>

                <div class="review-scores">
                    <div class="score-item">
                        <span class="score-label">Service:</span>
                        <div class="star-rating small">
                            {{{renderStars scores.service}}}
                        </div>
                    </div>
                    <div class="score-item">
                        <span class="score-label">Taste:</span>
                        <div class="star-rating small">
                            {{{renderStars scores.taste}}}
                        </div>
                    </div>
                    <div class="score-item">
                        <span class="score-label">Ambiance:</span>
                        <div class="star-rating small">
                            {{{renderStars scores.ambiance}}}
                        </div>
                    </div>
                </div>

                <div class="review-title-2">{{title}}</div>
                <div class="review-text-2">{{content}}</div>
            </div>
            {{/each}}
        </div>
    </section>

    <script src="script.js"></script>
</body>
</html>