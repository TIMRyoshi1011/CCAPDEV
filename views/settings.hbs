<style>
    :root {
        --bg-body: #F9F8F6;
        --card-bg: #ffffff;
        --text-dark: #333333;
        --text-muted: #8e8e8e;
        --brand-pink: #E94E66;
        --brand-blue: #4A60A1;
        --border: #eeeeee;
    }

    body {
        background-color: var(--bg-body);
    }

    .main-content {
        font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
        color: var(--text-dark);
        line-height: 1.5;
        padding: 40px 20px;
        max-width: 700px;
        margin: 0 auto;
    }

    .account,
    .notifications,
    .others,
    .tier-system {
        background: var(--card-bg);
        border-radius: 16px;
        padding: 24px;
        margin-bottom: 24px;
        border: 1px solid var(--border);
        box-shadow: 0 2px 8px rgba(0, 0, 0, 0.03);
    }

    h3 {
        margin-top: 0;
        font-size: 14px;
        text-transform: uppercase;
        letter-spacing: 1px;
        color: var(--brand-blue);
    }

    /* Account Section Layout */
    .account {
        display: grid;
        grid-template-columns: auto 1fr auto;
        gap: 15px;
        align-items: center;
    }

    .account h3 {
        grid-column: 1 / -1;
    }

    .user-stats {
        grid-column: 1 / -1;
        display: grid;
        grid-template-columns: 1fr 1fr 1fr;
        gap: 12px;
        margin-top: 10px;
    }

    .stat-card {
        background: #f8f9fa;
        border: 1px solid #e5e7eb;
        border-radius: 12px;
        padding: 12px;
        text-align: center;
        display: flex;
        flex-direction: column;
        justify-content: center;
        align-items: center;
    }

    .stat-card .label {
        font-size: 11px;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        color: #6b7280;
        margin-bottom: 4px;
        font-weight: 600;
    }
    
    .stat-card .value {
        font-size: 15px;
        font-weight: 700;
        color: #111827;
    }

    .profile-pic {
        width: 60px;
        height: 60px;
        background: #d94866;
        color: white;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-weight: bold;
        font-size: 20px;
    }

    .user-info .name {
        display: block;
        font-weight: bold;
        font-size: 18px;
    }

    .user-info .username {
        color: var(--text-muted);
        font-size: 14px;
    }

    .membership-status {
        text-align: right;
    }

    .status {
        background: #2061a3;
        color: #b6d9ff;
        padding: 4px 12px;
        border-radius: 20px;
        font-size: 11px;
        font-weight: bold;
    }

    .member-date {
        font-size: 11px;
        color: var(--text-muted);
        margin-top: 5px;
    }

    /* Stats (Tier/Points) */
    .current-tier,
    .points,
    .next-tier {
        background: #fcfcfc;
        border: 1px solid var(--border);
        padding: 12px;
        border-radius: 12px;
        text-align: center;
    }

    .label {
        display: block;
        font-size: 14px;
        font-weight: bold;
        color: #000000;
        margin-bottom: 2px;
    }

    .value {
        font-size: 14px;
    }

    .points .value {
        color: var(--brand-pink);
    }

    /* Forms & Inputs */
    textarea {
        width: 100%;
        border: 1px solid var(--border);
        border-radius: 8px;
        padding: 12px;
        box-sizing: border-box;
        font-family: inherit;
        resize: vertical;
    }

    input[type="submit"],
    button {
        background: var(--brand-pink);
        color: white;
        border: none;
        padding: 10px 20px;
        border-radius: 8px;
        font-weight: bold;
        cursor: pointer;
        margin-top: 10px;
        transition: opacity 0.2s;
    }

    #delete-account {
        background: var(--brand-pink);
    }

    button:hover {
        opacity: 0.8;
    }

    /* Notifications & Toggles */
    .public-profile,
    .show-tier {
        justify-content: space-between;
        align-items: center;
        padding: 15px 0;
        border-bottom: 1px solid #f9f9f9;
    }

    .description {
        font-size: 12px;
        color: var(--text-muted);
        display: block;
    }

    /* The Toggle Switch */
    .switch {
        position: relative;
        align-items: auto;
        display: flex;
        width: 44px;
        height: 24px;
    }

    .switch input {
        opacity: 0;
        width: 0;
        height: 0;
    }

    .slider {
        position: absolute;
        cursor: pointer;
        top: 0;
        left: 0;
        right: 0;
        bottom: 0;
        background-color: #ccc;
        transition: .4s;
        border-radius: 34px;
    }

    .slider:before {
        position: absolute;
        content: "";
        height: 18px;
        width: 18px;
        left: 3px;
        bottom: 3px;
        background-color: white;
        transition: .4s;
        border-radius: 50%;
    }

    input:checked+.slider {
        background-color: var(--brand-pink);
    }

    input:checked+.slider:before {
        transform: translateX(20px);
    }

    /* Tier System Info Box */
    .tier-system {
        background: #FFF0F2;
        border-color: #FFE5E9;
    }

    .tier-system .label {
        color: var(--brand-pink);
        font-size: 14px;
        margin-bottom: 10px;
    }

    .tier-system .description {
        color: #666;
        margin-bottom: 8px;
    }

    .tier-system .description::before {
        content: "• ";
        color: var(--brand-pink);
    }

    /* Other Settings */
    .others .description {
        margin-top: 5px;
    }

    /* Popup Overlay */
    .popup {
        position: fixed;
        z-index: 9999;
        left: 0;
        top: 0;
        width: 100%;
        height: 100%;
        overflow: auto;
        background-color: rgba(0, 0, 0, 0.4);
        display: flex;
        align-items: center;
        justify-content: center;
        opacity: 1;
        transition: opacity 0.3s ease;
    }

    .popup.hidden {
        opacity: 0;
        pointer-events: none;
    }

    .popup-content {
        background-color: #fefefe;
        margin: auto;
        padding: 30px;
        border: 1px solid #888;
        width: 80%;
        max-width: 400px;
        border-radius: 16px;
        position: relative;
        box-shadow: 0 10px 25px rgba(0,0,0,0.1);
    }

    .close {
        color: #aaa;
        position: absolute;
        top: 15px;
        right: 20px;
        font-size: 28px;
        font-weight: bold;
        cursor: pointer;
        line-height: 1;
    }

    .close:hover,
    .close:focus {
        color: black;
        text-decoration: none;
        cursor: pointer;
    }

    .success-icon-container {
        width: 60px;
        height: 60px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        margin: 0 auto 20px;
        color: white;
        font-size: 30px;
        font-weight: bold;
    }

    .success-title {
        margin: 0 0 10px;
        color: #333;
        font-size: 22px;
    }

    .success-message {
        color: #666;
        margin-bottom: 25px;
        line-height: 1.5;
    }

    .success-done-btn {
        background-color: #4CAF50;
        color: white;
        border: none;
        padding: 12px 30px;
        border-radius: 25px;
        font-size: 16px;
        cursor: pointer;
        font-weight: bold;
        transition: transform 0.1s, box-shadow 0.1s;
        box-shadow: 0 4px 6px rgba(76, 175, 80, 0.2);
        width: 100%;
    }

    .success-done-btn:active {
        transform: scale(0.98);
    }

</style>

<div class="main-content-2">

    <div class="account">
        <h3>Account</h3>

        <div class="profile-pic">
            {{currentUser.avatar}}
        </div>

        <div class="user-info">
            <span class="name">{{currentUser.name}}</span>
            <span class="username">@{{currentUser.username}}</span>
        </div>

        <div class="membership-status">
            <span class="status">{{currentUser.tier}} Member</span>
            <p class="member-date">Member since {{currentUser.memberSince}}</p>
        </div>

        <div class="user-stats">
            <div class="stat-card current-tier">
                <span class="label">Current Tier</span>
                <span class="value">{{currentUser.tierIcon}} {{currentUser.tier}}</span>
            </div>

            <div class="stat-card points">
                <span class="label">Points</span>
                <span class="value">{{currentUser.points}}</span>
            </div>

            <div class="stat-card next-tier">
                <span class="label">Next Tier</span>
                <span class="value">{{currentUser.nextTier}}</span>
            </div>
        </div>
    </div>



    <div class="notifications">
        <h3>Notifications</h3>

        <div class="tier-system">
             <div>
                 <span class="label" style="display: block; font-weight: bold; margin-bottom: 5px;">Points & Tiers Guide</span>
                 <p class="description" style="margin: 0;"> Earn points by writing reviews (10pts), getting upvotes (2pts), or comments (1pt). Downvotes reduce points (-1pt).</p>
                 <br>
                 <span class="label" style="display: block; font-weight: bold; margin-bottom: 5px;">Tiers & Badges</span>
                 <ul style="padding-left: 20px; margin: 0; font-size: 13px; color: #666;">
                    <li>🥉 <b>Bronze</b> (0-49 pts)</li>
                    <li>🥈 <b>Silver</b> (50-199 pts) - Verified Badge</li>
                    <li>🥇 <b>Gold</b> (200-499 pts)</li>
                    <li>💎 <b>Platinum</b> (500+ pts)</li>
                 </ul>
            </div>
        </div>


        <div class="others">
            <h3>Account Settings</h3>

            <div class="change-password-setting">
                <button id="change-password-btn" onclick="openUpdatePassword()">Change Password</button>
                <div class="description" style="margin-top: 5px;">
                    Update your account password securely.
                </div>
            </div>

            <div class="logout-setting">
                <br>
                <button id="logout" onclick="logout()" style="background-color: var(--text-muted);">Log Out</button>
                <div class="description" style="margin-top: 5px;">
                    End your session on this device.
                </div>
            </div>

            <div class="delete-account-setting">
                <br>
                <button class="delete-btn" onclick="openDeleteAccountConfirm()" style="background-color: #d94866;">Delete Account</button>
                <div class="description" style="margin-top: 5px;">
                    Permanently delete your account and all data. Cannot be undone.
                </div>
                <br>
            </div>
        </div>

    </div>

</div>

<!-- Delete Account Confirm Popup -->
<div id="deleteAccountConfirmPopup" class="popup hidden">
    <div class="popup-content" style="text-align: center;">
        <span class="close" onclick="closeDeleteAccountConfirm()">&times;</span>
        <div class="success-icon-container" style="background-color: #d94866; box-shadow: 0 4px 12px rgba(217, 72, 102, 0.3);">
            <span>!</span>
        </div>
        <h2 class="success-title">Delete Account?</h2>
        <p class="success-message">
            Are you sure you want to delete your account? This action is permanent and cannot be undone. All your data will be lost.
        </p>
        <div style="display: flex; justify-content: center; gap: 12px; margin-top: 20px;">
            <button class="success-done-btn" onclick="submitDeleteAccount()" style="width: 120px; background-color: #d94866;">Delete</button>
            <button class="success-done-btn" onclick="closeDeleteAccountConfirm()" style="width: 120px; background-color: #f3f4f6; color: #4b5563; box-shadow: none;">Cancel</button>
        </div>
    </div>
</div>